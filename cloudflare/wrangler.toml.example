name = "1200km-agent-readiness"
main = "cloudflare/agent-readiness-worker.js"
compatibility_date = "2026-07-01"

# Deploy this Worker on the proxied Cloudflare zone:
# routes = [
#   { pattern = "1200km.com/*", zone_name = "1200km.com" }
# ]

# The Worker is intentionally read-only:
# - adds RFC 8288 Link response headers
# - serves Markdown mirrors when Accept: text/markdown is requested
# - fixes content types for agent discovery files

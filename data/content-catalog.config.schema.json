{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://1200km.com/data/content-catalog.config.schema.json",
  "title": "1200km content catalogue generation policy",
  "type": "object",
  "required": ["$schema", "catalog_version", "verified_at", "major_indexes", "additional_pages", "featured_urls", "core_urls", "declared_collections", "aliases", "declared_items", "overrides"],
  "properties": {
    "$schema": { "const": "./content-catalog.config.schema.json" },
    "catalog_version": { "type": "string" },
    "verified_at": { "type": "string", "format": "date" },
    "major_indexes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "additional_pages": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "featured_urls": { "type": "array", "items": { "type": "string", "format": "uri" }, "uniqueItems": true },
    "core_urls": { "type": "array", "items": { "type": "string", "format": "uri" }, "uniqueItems": true },
    "declared_collections": { "type": "array" },
    "aliases": { "type": "array" },
    "declared_items": { "type": "array" },
    "overrides": { "type": "object" }
  },
  "additionalProperties": false
}

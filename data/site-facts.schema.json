{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://1200km.com/data/site-facts.schema.json",
  "title": "1200km authoritative site facts",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "model_version", "facts"],
  "properties": {
    "$schema": { "const": "./site-facts.schema.json" },
    "model_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "facts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/fact" }
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "scope", "verified_at", "source", "status"],
      "properties": {
        "value": {},
        "scope": { "type": "string", "minLength": 1 },
        "verified_at": { "type": "string", "format": "date" },
        "source": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "status": {
          "enum": [
            "released",
            "current-development",
            "maintained",
            "experimental",
            "submitted",
            "accepted",
            "closed-unmerged",
            "superseded",
            "archived",
            "verified"
          ]
        },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}

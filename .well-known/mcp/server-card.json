{
  "serverInfo": {
    "name": "1200km Public Knowledge Server",
    "version": "1.0.0",
    "description": "Public discovery card for 1200km.com, a cybersecurity portfolio and AdversaryGraph documentation hub."
  },
  "transport": {
    "type": "none",
    "description": "No public MCP transport is currently exposed. This card is used for discovery of public documentation and read-only capabilities."
  },
  "capabilities": {
    "resources": true,
    "tools": false,
    "prompts": false
  },
  "resources": [
    {
      "name": "LLM Site Summary",
      "uri": "https://1200km.com/llms.txt",
      "mimeType": "text/plain"
    },
    {
      "name": "Agent Index",
      "uri": "https://1200km.com/agent-index.md",
      "mimeType": "text/markdown"
    },
    {
      "name": "Authoritative Site Facts",
      "uri": "https://1200km.com/data/site-facts.json",
      "mimeType": "application/json"
    },
    {
      "name": "AdversaryGraph Documentation",
      "uri": "https://1200km.com/adversarygraph-docs/",
      "mimeType": "text/html"
    },
    {
      "name": "AdversaryGraph Capabilities",
      "uri": "https://1200km.com/adversarygraph-docs/capabilities/",
      "mimeType": "text/html"
    }
  ],
  "safety": {
    "publicUse": "Documentation and read-only discovery only",
    "restrictedActions": [
      "malware upload",
      "attack simulation execution",
      "SIEM forwarding",
      "private IOC queries",
      "authenticated platform workflows"
    ]
  }
}
